# ========================================
# Frontend Environment Configuration
# ========================================

# Backend API URL
# Change this to your production API URL when deploying
REACT_APP_API_URL=http://localhost:5000

# App Configuration
REACT_APP_NAME=MERN Review System
REACT_APP_VERSION=2.0.0

# Feature Flags
# Enable/disable features (true/false)
REACT_APP_ENABLE_STAR_RATING=true
REACT_APP_ENABLE_NESTED_COMMENTS=true
REACT_APP_ENABLE_PUBLIC_REVIEWS=true

# UI Configuration
REACT_APP_REVIEWS_PER_PAGE=10
REACT_APP_MIN_COMMENT_LENGTH=10
REACT_APP_MAX_COMMENT_LENGTH=1000

# ========================================
# NOTES:
# ========================================
# 1. Copy this file to .env for local development
# 2. Update REACT_APP_API_URL to your backend URL
# 3. In production, set REACT_APP_API_URL to your deployed backend
# 4. All REACT_APP_* variables are embedded in the build
